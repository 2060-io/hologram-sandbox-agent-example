# =============================================================================
# Example Agent VS — Configuration
# =============================================================================
#
# This file is read by the setup/start scripts, Docker Compose, and GHA workflow.
# It contains all configuration needed for the Example Agent service.
#
# For local testing:
#   source config.env
#   ./scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Agent public URL (used to check existing credentials on the DID document)
# When you fork this repo, override this variable with your own public URL.
# Convention: https://<agent-name>.<your-namespace>.sandbox.hologram.zone
# or anything that resolves to your ingress host.
# ---------------------------------------------------------------------------
AGENT_PUBLIC_URL="${AGENT_PUBLIC_URL:-https://example-agent.sandbox.hologram.zone}"

# ---------------------------------------------------------------------------
# Organization — parent service (hologram-sandbox-deps)
# The admin API is used to request Service credentials.
# ---------------------------------------------------------------------------
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL:-https://organization.sandbox.hologram.zone}"
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL%/}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL:-https://admin.organization.sandbox.hologram.zone}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL%/}"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# Use different ports than organization (3000/3001) and avatar (3002/3003).
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="example-agent"
VS_AGENT_ADMIN_PORT="3010"
VS_AGENT_PUBLIC_PORT="3011"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential issued by organization.
# ---------------------------------------------------------------------------
SERVICE_NAME="Hologram Example Agent"
SERVICE_TYPE="AIAgent"
SERVICE_DESCRIPTION="Example Hologram AI agent with Context7 MCP integration"
SERVICE_LOGO_URL="https://hologram.zone/logo-squared.svg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://verana.io/terms"
SERVICE_PRIVACY="https://verana.io/privacy"

# ---------------------------------------------------------------------------
# Chatbot configuration (hologram-ai-agent)
# ---------------------------------------------------------------------------
CHATBOT_IMAGE="${CHATBOT_IMAGE:-io2060/hologram-ai-agent:v1.13.1}"
CHATBOT_PORT="3003"

# LLM
LLM_PROVIDER="openai"
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_API_KEY="${OPENAI_API_KEY:-}"

# RAG
RAG_PROVIDER="langchain"
RAG_DOCS_PATH="/app/rag/docs"

# Memory
AGENT_MEMORY_BACKEND="redis"
AGENT_MEMORY_WINDOW="20"

# ---------------------------------------------------------------------------
# Credential authentication (hologram-sandbox-deps avatar credDef)
# AnonCreds credential definition ID used to authenticate users.
# The default below points at the shared sandbox avatar issuer
# (avatar.sandbox.hologram.zone). Override only if you deploy your own deps:
#   1. Run the `2_deploy-avatar` workflow with step=all
#   2. Copy the `CREDENTIAL_DEFINITION_ID` from the workflow summary
# ---------------------------------------------------------------------------
CREDENTIAL_DEFINITION_ID="${CREDENTIAL_DEFINITION_ID:-did:webvh:QmceGMnCK8ncVMqARwRBfhsg35sPomqovjaj9ckCtbXj8M:avatar.sandbox.hologram.zone/resources/zQmQtULNvy7XDjWCsRr9wXzw8u5Wa2Qo2t8n2oGx8fvjFyJ}"

# ---------------------------------------------------------------------------
# MCP — Context7 (docs lookup, zero-auth)
# Context7 is a public MCP server that exposes library / documentation tools.
# Swap or add more servers by editing agent-pack.yaml (mcp.servers).
# ---------------------------------------------------------------------------
CONTEXT7_MCP_URL="${CONTEXT7_MCP_URL:-https://mcp.context7.com/mcp}"

# MCP config encryption — required only if you add a user-controlled MCP server
# (e.g. GitHub with per-user PAT). Generate with: openssl rand -hex 32
MCP_CONFIG_ENCRYPTION_KEY="${MCP_CONFIG_ENCRYPTION_KEY:-}"

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD="${POSTGRES_PASSWORD:-changeme}"
POSTGRES_USER="example_agent_db"
POSTGRES_DB="example-agent"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL="info"
